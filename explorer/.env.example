# Mapbox Access Token
# Preferred: set MAPBOX_ACCESS_TOKEN for server-side rendering (works in Vercel preview deployments
# without being baked into the client bundle at build time).
MAPBOX_ACCESS_TOKEN=

# Legacy fallback: NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN is baked into the client bundle at build time.
# Use this only if you need the token available in fully static / client-only contexts.
# NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

node_modules
.next
.DS_Store
.env*
!.env.example
.vercel
.env*.local

# Territory GeoJSON in public/ is copied from data/ at build time
public/data/territories/

# Power plants JSON in public/ is copied from data/ at build time
public/data/power-plants.json

# Transmission lines JSON in public/ is copied from data/ at build time
public/data/transmission-lines.json

# EV charging JSON in public/ is copied from data/ at build time
public/data/ev-charging.json

# Transmission lines GeoJSON can be large (regenerate from sync script)
data/transmission-lines.geojson

# PMTiles archives (built by scripts/build-tiles.sh via tippecanoe)
# Track the .pmtiles files but ignore any extracted/legacy tile directories
public/tiles/*
!public/tiles/*.pmtiles

# Changelog snapshot — large JSON used only for diffing during sync
# changelog.json itself is tracked; only the snapshot dir is ignored
data/.snapshot/

# Visual regression capture output (generated, not tracked)
.visual-regression/
